# FastAPI 設定
SECRET_KEY=dev-secret-key
PORT=5000
DAILY_TOKEN_LIMIT=0

# Qwen / OpenAI 相容設定
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-max
OPENAI_API_KEY=

# 資料庫
DB_PATH=requirement_compass.db

# 各模式題數（不填即用預設）
# 影片/生圖/音樂：*_FIRST_ROUND 與 *_FOLLOWUP 為「不含最後補充題」的題數
VIDEO_QUESTIONS_FIRST_ROUND=12
VIDEO_QUESTIONS_FOLLOWUP=12
IMAGE_QUESTIONS_FIRST_ROUND=9
IMAGE_QUESTIONS_FOLLOWUP=9
MUSIC_QUESTIONS_FIRST_ROUND=12
MUSIC_QUESTIONS_FOLLOWUP=12
CODING_QUESTIONS_FIRST_ROUND=10
CODING_QUESTIONS_FOLLOWUP=10
DIALOGUE_QUESTIONS_FIRST_ROUND=10
DIALOGUE_QUESTIONS_FOLLOWUP=10
